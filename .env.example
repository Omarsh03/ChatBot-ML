# Core app
APP_NAME=Course RAG Chatbot
APP_ENV=dev
LOG_LEVEL=INFO

# Course selection (MVP: single course)
DEFAULT_COURSE_ID=machine_learning

# Data paths
DATA_DIR=./data
MEDIA_DIR=./data/media
TRANSCRIPTS_DIR=./data/transcripts
INDEX_DIR=./data/indexes
METADATA_DIR=./data/metadata

# RAG behavior defaults
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CHUNK_QUALITY_FILTER_ENABLED=true
MIN_CHUNK_ALPHA_RATIO=0.35
MAX_CHUNK_DIGIT_RATIO=0.30
MIN_CHUNK_UNIQUE_TOKEN_RATIO=0.20
MAX_CHUNK_REPEATED_TOKEN_RUN=10
TOP_K=6
RETRIEVAL_POOL_K=36
EMBEDDING_DIM=256
MIN_RETRIEVAL_SCORE=0.30
MIN_EVIDENCE_HITS=1
MIN_LEXICAL_OVERLAP=0.12
PROBABILITY_RETRIEVAL_POOL_K=48
PROBABILITY_MIN_RETRIEVAL_SCORE=0.22
PROBABILITY_MIN_LEXICAL_OVERLAP=0.08
PROBABILITY_MIN_EVIDENCE_HITS=1
INSUFFICIENT_EVIDENCE_MESSAGE=I do not have enough evidence from the course transcripts to answer this confidently.
TRANSCRIPTION_MANIFEST_NAME=lectures_manifest.json
TRANSCRIPTION_LECTURES_METADATA_NAME=lectures.json

# Provider configuration
LLM_PROVIDER=openai
USE_LLM_GROUNDED_ANSWERS=false
EMBEDDING_PROVIDER=local_hash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RERANK_PROVIDER=none
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0
